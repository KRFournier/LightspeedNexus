<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LightspeedNexus.ViewModels"
			 xmlns:v="clr-namespace:LightspeedNexus.Views"
			 xmlns:c="clr-namespace:LightspeedNexus.Controls"
             mc:Ignorable="d" d:DesignWidth="550" d:DesignHeight="450"
             x:Class="LightspeedNexus.Dialogs.LoginDialog"
			 KeyDown="UserControl_KeyDown">

	<StackPanel Spacing="10"
			    HorizontalAlignment="Center"
				VerticalAlignment="Center">

		<c:LightspeedBorder Classes="sabersport"
					        Padding="20">

			<Grid ColumnDefinitions="Auto,10,*"
		          RowDefinitions="Auto,Auto,10,Auto,Auto">

				<TextBlock Grid.Column="0"
						   Grid.Row="0"
						   VerticalAlignment="Center"
						   Text="Email"/>
				<TextBox x:Name="EmailTextBox"
			             Classes="sabersport"
						 Grid.Column="2"
						 Grid.Row="0"
						 Width="400"/>
				<HyperlinkButton x:Name="RegisterButton"
								 Foreground="{StaticResource Green}"
								 Grid.Column="2"
								 Grid.Row="1"
								 HorizontalAlignment="Right"
								 Content="Register"
								 Click="RegisterButton_Click"/>

				<TextBlock Grid.Column="0"
						   Grid.Row="3"
						   VerticalAlignment="Center"
						   Text="Password"/>
				<TextBox x:Name="PasswordTextBox"
				         Classes="sabersport"
						 Grid.Column="2"
						 Grid.Row="3"
						 PasswordChar="*"
						 Width="400"/>
				<CheckBox x:Name="RememberCheckBox"
			              Grid.Column="2"
						  Grid.Row="4"
						  Classes="sabersport"
						  Content="Remember"/>
				<StackPanel Orientation="Horizontal"
						    HorizontalAlignment="Right"
							Spacing="10"
			                Grid.Column="2"
						    Grid.Row="4">
					<HyperlinkButton x:Name="ResendButton"
									 Foreground="{StaticResource Green}"
									 Content="Resend"
									 Click="ResendButton_Click"/>
					<HyperlinkButton x:Name="RenewButton"
									 Foreground="{StaticResource Green}"
									 Content="Request New"
									 Click="RenewButton_Click"/>
				</StackPanel>

			</Grid>

		</c:LightspeedBorder>

		<!--Buttons-->
		<StackPanel Orientation="Horizontal"
			        Spacing="10"
					HorizontalAlignment="Right">

			<Button x:Name="CancelButton" Classes="gray" Width="75" Click="Cancel_Click">
				<TextBlock Text="Cancel" HorizontalAlignment="Center"/>
			</Button>

			<Button x:Name="OkButton" Classes="sabersport" Width="75" Click="OK_Click">
				<TextBlock Text="OK" HorizontalAlignment="Center"/>
			</Button>

		</StackPanel>

	</StackPanel>
	
</UserControl>
