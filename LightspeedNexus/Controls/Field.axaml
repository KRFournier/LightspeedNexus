<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:c="clr-namespace:LightspeedNexus.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LightspeedNexus.Controls.Field">

	<Grid RowDefinitions="Auto" Margin="0,5">

		<!-- This allows multiple field to line up their label -->
		<ColumnDefinitions>
			<ColumnDefinition SharedSizeGroup="FieldLabelColumn" />
			<ColumnDefinition Width="*"/>
		</ColumnDefinitions>
		
		<!-- Label element, its Grid.Row and Grid.Column will be set in code-behind -->
		<Label x:Name="PART_Label"
               Content="{Binding $parent[c:Field].LabelText}"
               VerticalAlignment="Center"
               Margin="0,0,5,0" />

		<!-- TextBox element, its Grid.Row and Grid.Column will be set in code-behind -->
		<TextBox x:Name="PART_TextBox"
				 Grid.Column="1"
                 Text="{Binding $parent[c:Field].Text, Mode=TwoWay}"
                 Watermark="{Binding $parent[c:Field].PlaceholderText}"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Center" />
	</Grid>
	
</UserControl>
