<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  
    <Design.PreviewWith>
		<Border Padding="20">
			<StackPanel Spacing="20">
				<Button Content="Click Me!" />
				<Button Classes="clear" Content="Click Me!" />
				<Button Classes="gray" Content="Click Me!" />
				<Button Classes="red" Content="Click Me!" />
				<Button Classes="green" Content="Click Me!" />
			</StackPanel>
		</Border>
    </Design.PreviewWith>

	<Styles.Resources>
		<Color x:Key="Blue">#21458d</Color>
		<Color x:Key="Red">#b52d25</Color>
		<Color x:Key="Green">#218d21</Color>
		<Color x:Key="Gray">#4c4c4c</Color>
	</Styles.Resources>

	<Style Selector="Button">
		<Style Selector="^.gray">
			<Setter Property="BorderBrush" Value="{StaticResource Gray}"/>
			<Setter Property="Background">
				<SolidColorBrush Color="{StaticResource Gray}" Opacity="0.4"/>
			</Setter>
		</Style>
		<Style Selector="^.red">
			<Setter Property="BorderBrush" Value="{StaticResource Red}"/>
			<Setter Property="Background">
				<SolidColorBrush Color="{StaticResource Red}" Opacity="0.4"/>
			</Setter>
		</Style>
		<Style Selector="^.green">
			<Setter Property="BorderBrush" Value="{StaticResource Green}"/>
			<Setter Property="Background">
				<SolidColorBrush Color="{StaticResource Green}" Opacity="0.4"/>
			</Setter>
		</Style>
		<Style Selector="^.clear">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
		</Style>
	</Style>
	
</Styles>
