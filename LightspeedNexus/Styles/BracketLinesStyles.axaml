<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:c="clr-namespace:LightspeedNexus.Controls">
  
    <Design.PreviewWith>
		<Border Padding="20" Background="#1f1f1f">
			<StackPanel Spacing="20">
				<c:BracketLines Height="200" Width="75"/>
			</StackPanel>
		</Border>
    </Design.PreviewWith>

	<Style Selector="c|BracketLines">
		<Setter Property="LineThickness" Value="2.0"/>
		<Setter Property="CornerRadius" Value="5.0"/>
		<Setter Property="LineBrush">
			<Setter.Value>
				<SolidColorBrush Color="White" Opacity="0.2"/>
			</Setter.Value>
		</Setter>
	</Style>
	
</Styles>
