<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:c="clr-namespace:LightspeedNexus.Controls">
  
    <Design.PreviewWith>
		<Border Padding="20">
			<StackPanel Spacing="20">
				<c:HoldButton Content="Click Me!" />
				<c:HoldButton Classes="delete" Content="Click Me!" />
				<c:HoldButton Classes="gray" Content="Click Me!" />
				<c:HoldButton Classes="error" Content="Click Me!" />
				<c:HoldButton Classes="noscale" Content="Click Me!" />
			</StackPanel>
		</Border>
    </Design.PreviewWith>

	<Style Selector="c|HoldButton">	
	</Style>
	
</Styles>
