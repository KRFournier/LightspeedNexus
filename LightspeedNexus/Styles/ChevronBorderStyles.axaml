<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:c="clr-namespace:LightspeedNexus.Controls">
  
    <Design.PreviewWith>
		<Border Padding="20" Background="#1f1f1f">
			<StackPanel Spacing="0">
				<c:ChevronBorder Classes="">
					<TextBlock HorizontalAlignment="Center">Setup</TextBlock>
				</c:ChevronBorder>
				<c:ChevronBorder Classes="blue">
					<TextBlock HorizontalAlignment="Center">Squadrons</TextBlock>
				</c:ChevronBorder>
				<c:ChevronBorder Classes="">
					<TextBlock HorizontalAlignment="Center">Pools</TextBlock>
				</c:ChevronBorder>
			</StackPanel>
		</Border>
    </Design.PreviewWith>

	<Style Selector="c|ChevronBorder">
		<Setter Property="Background" Value="{StaticResource BlackBackground}"/>
		<Setter Property="BorderBrush" Value="{StaticResource Gray}"/>
		<Setter Property="Padding" Value="10,20"/>
		<Setter Property="ArrowDepth" Value="12"/>
		<Setter Property="Margin" Value="0"/>
		<Style Selector="^.blue">
			<Setter Property="Background" Value="{StaticResource BlueBackground}"/>
			<Setter Property="BorderBrush" Value="{StaticResource Blue}"/>
		</Style>
	</Style>
	
</Styles>
