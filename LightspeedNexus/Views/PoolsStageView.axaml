<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LightspeedNexus.ViewModels"
			 xmlns:m="clr-namespace:LightspeedNexus.Models"
			 xmlns:v="clr-namespace:LightspeedNexus.Views"
			 xmlns:c="clr-namespace:LightspeedNexus.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 ClipToBounds="False"
             x:Class="LightspeedNexus.Views.PoolsStageView"
			 x:DataType="vm:PoolsStageViewModel">

	<Grid RowDefinitions="Auto,10,*">

		<!--Header-->
		<Grid ColumnDefinitions="260,10,*,10,260">
			<Button HorizontalAlignment="Stretch"
					VerticalAlignment="Stretch"
					HorizontalContentAlignment="Center"
					VerticalContentAlignment="Center"
					Command="{Binding GoBackCommand}">
				<StackPanel>
					<StackPanel>
						<StackPanel Orientation="Horizontal"
									Spacing="10">
							<PathIcon Data="{StaticResource arrow_left_regular}"/>
							<TextBlock Classes="large" Text="Squadrons"/>
						</StackPanel>
						<StackPanel Orientation="Horizontal"
									Spacing="2">
							<PathIcon Data="{StaticResource warning_regular}"
									  VerticalAlignment="Center"
									  Height="12"/>
							<TextBlock Classes="info"
									   VerticalAlignment="Center"
									   Text="Matches will be reset"/>
						</StackPanel>
					</StackPanel>
				</StackPanel>
			</Button>
			<TextBlock Classes="giant"
					   Grid.Column="2"
					   HorizontalAlignment="Center"
					   VerticalAlignment="Center"
					   Text="{Binding Title}"/>
			<Button Grid.Column="4"
					HorizontalAlignment="Stretch"
					VerticalAlignment="Stretch"
					HorizontalContentAlignment="Center"
					VerticalContentAlignment="Center">
				<StackPanel>
					<StackPanel Orientation="Horizontal"
								Spacing="10">
						<TextBlock Classes="large" Text="Results"/>
						<PathIcon Data="{StaticResource arrow_right_regular}"/>
					</StackPanel>
				</StackPanel>
			</Button>
		</Grid>
		
		<!--Pools-->
		<Panel Grid.Column="2" Grid.Row="2">

			<ScrollViewer x:Name="PoolsScrollViewer" 
						  HorizontalScrollBarVisibility="Auto"
						  VerticalScrollBarVisibility="Hidden">
				<ItemsControl ItemsSource="{Binding Pools}"
							  Height="{Binding $parent.Bounds.Height}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Horizontal" Spacing="10"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate DataType="vm:PoolViewModel">
							<StackPanel SizeChanged="OnPoolSizeChanged"
										Spacing="10">
								<TextBlock Text="{Binding Squadron.Name, StringFormat='{}{0} Squadron'}"
										   Classes="large"
										   Foreground="{Binding Squadron.Color}"
										   HorizontalAlignment="Center"
										   IsHitTestVisible="False"/>
								<v:MatchSettingsView DataContext="{Binding Squadron.Settings}"
													 Height="100"
													 HorizontalAlignment="Center"/>

								<!--Matches-->
								<ItemsControl ItemsSource="{Binding Matches}">
									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<WrapPanel Orientation="Vertical"/>
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>
									<ItemsControl.ItemTemplate>
										<DataTemplate DataType="vm:MatchViewModel">
											<c:SimpleLightspeedBorder Classes="small growcorners"
																	  Margin="0,0,10,10"
																	  Padding="0"
																	  Brush="{Binding $parent[StackPanel].((vm:PoolViewModel)DataContext).Squadron.Color}"
																	  SelectionBrush="{StaticResource HilightBrush}"
																	  IsSelected="{Binding IsLive}">
												<ContentControl Content="{Binding .}"/>
											</c:SimpleLightspeedBorder>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
								
							</StackPanel>											
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>
			
		</Panel>

	</Grid>
	
</UserControl>
