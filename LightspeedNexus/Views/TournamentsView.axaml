<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LightspeedNexus.ViewModels"
			 xmlns:v="clr-namespace:LightspeedNexus.Views"
			 xmlns:m="clr-namespace:LightspeedNexus.Models"
			 xmlns:c="using:Lightspeed.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LightspeedNexus.Views.TournamentsView"
			 x:DataType="vm:TournamentsViewModel">

	<Grid RowDefinitions="Auto,*">

		<!--Top Bar-->
		<Grid ColumnDefinitions="Auto,10,*,10,120" Margin="0,0,0,10">

			<Button Classes="clear"
					Command="{Binding GoHomeCommand}">
				<PathIcon Data="{StaticResource arrow_left_regular}"/>
			</Button>

			<TextBox Grid.Column="2"
					 PlaceholderText="Search..."
					 Text="{Binding SearchText}">
				<TextBox.InnerRightContent>
					<Button Classes="clear"
							IsVisible="{Binding $parent[TextBox].Text, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
						    Command="{Binding ClearSearchCommand}">
						<PathIcon Data="{StaticResource dismiss_regular}"/>
					</Button>
				</TextBox.InnerRightContent>
			</TextBox>

			<TextBlock Grid.Column="4"
					   HorizontalAlignment="Center"
					   VerticalAlignment="Center"
					   Text="{Binding Tournaments.Count, StringFormat={}{0} Tournaments}"/>

		</Grid>

		<!--Tournaments-->
		<ScrollViewer Grid.Row="1"
					  HorizontalAlignment="Stretch"
				      VerticalAlignment="Stretch">
			<StackPanel Spacing="10">

				<TextBlock Classes="large" Text="Open" Margin="0,10"/>

				<ItemsControl ItemsSource="{Binding IncompleteTournaments}" Margin="20,0">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Spacing="10"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate DataType="m:Tournament">
							<c:LightspeedBorder Classes="item"
												DoubleTapped="Tournament_DoubleTapped">
								<StackPanel Spacing="10">
									<Grid ColumnDefinitions="*,10,Auto">
										<TextBlock Classes="medium"
													IsHitTestVisible="False"
													Text="{Binding SetupStage.Title}"/>
										<c:HoldButton Classes="delete reveal-button"
													  Grid.Column="2"
													  Command="{Binding $parent[ScrollViewer].((vm:TournamentsViewModel)DataContext).DeleteTournamentCommand}"
													  CommandParameter="{Binding .}">
											<StackPanel Orientation="Horizontal"
														Spacing="8"
														VerticalAlignment="Center"
														HorizontalAlignment="Center">
												<TextBlock Classes="reveal-text tiny info"
															VerticalAlignment="Center"
															Text="(Hold to Delete)"/>
												<PathIcon Data="{StaticResource delete_regular}"/>
											</StackPanel>
										</c:HoldButton>
									</Grid>
									<Grid ColumnDefinitions="*,10,Auto,4,Auto,15">
										<TextBlock Classes="info"
													IsHitTestVisible="False"
													Text="{Binding SetupStage.Date, StringFormat='MMMM dd, yyyy'}"/>
										<PathIcon Data="{StaticResource person_regular}"
													Height="16"
													Grid.Column="2"/>
										<TextBlock Classes="info"
													Grid.Column="4"
													IsHitTestVisible="False"
													Text="{Binding SetupStage.Registrees.Length}"/>
									</Grid>
								</StackPanel>
							</c:LightspeedBorder>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

				<TextBlock Classes="large" Text="Completed" Margin="0,10"/>

				<ItemsControl ItemsSource="{Binding CompleteTournaments}" Margin="20,0">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Spacing="10"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate DataType="m:Tournament">
							<c:LightspeedBorder Classes="item gold"
												DoubleTapped="Tournament_DoubleTapped">
								<StackPanel Spacing="10">
									<Grid ColumnDefinitions="*,10,Auto">
										<TextBlock Classes="medium"
													IsHitTestVisible="False"
													Text="{Binding SetupStage.Title}"/>
										<c:HoldButton Classes="delete reveal-button"
													  Grid.Column="2"
													  Command="{Binding $parent[ScrollViewer].((vm:TournamentsViewModel)DataContext).DeleteTournamentCommand}"
													  CommandParameter="{Binding .}">
											<StackPanel Orientation="Horizontal"
														Spacing="8"
														VerticalAlignment="Center"
														HorizontalAlignment="Center">
												<TextBlock Classes="reveal-text tiny info"
															VerticalAlignment="Center"
															Text="(Hold to Delete)"/>
												<PathIcon Data="{StaticResource delete_regular}"/>
											</StackPanel>
										</c:HoldButton>
									</Grid>
									<Grid ColumnDefinitions="*,10,Auto,4,Auto,15">
										<TextBlock Classes="info"
													IsHitTestVisible="False"
													Text="{Binding SetupStage.Date, StringFormat='MMMM dd, yyyy'}"/>
										<PathIcon Data="{StaticResource person_regular}"
													Height="16"
													Grid.Column="2"/>
										<TextBlock Classes="info"
													Grid.Column="4"
													IsHitTestVisible="False"
													Text="{Binding SetupStage.Registrees.Length}"/>
									</Grid>
								</StackPanel>
							</c:LightspeedBorder>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>
		</ScrollViewer>
		
	</Grid>
	
</UserControl>
