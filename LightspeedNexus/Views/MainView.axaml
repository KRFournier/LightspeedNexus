<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LightspeedNexus.ViewModels"
			 xmlns:v="clr-namespace:LightspeedNexus.Views"
			 xmlns:c="clr-namespace:LightspeedNexus.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="LightspeedNexus.Views.MainView"
             x:DataType="vm:MainViewModel"
			 FontFamily="{StaticResource Prototype}">
	
    <Design.DataContext>
		<vm:MainViewModel/>
    </Design.DataContext>

	<Panel x:Name="MainPanel">

		<Image Stretch="UniformToFill"
			   Source="/Assets/LightspeedBackground.png"
			   Opacity="0.5"/>

		<TransitioningContentControl x:Name="ContentControl"
									 Content="{Binding CurrentPage}"
									 ClipToBounds="False"
									 Margin="10">
			<TransitioningContentControl.PageTransition>
				<PageSlide Orientation="Vertical"
						   Duration="0:0:0.5"
						   SlideInEasing="CircularEaseOut"
						   SlideOutEasing="CircularEaseOut"/>
			</TransitioningContentControl.PageTransition>
		</TransitioningContentControl>
		
	</Panel>
	
</UserControl>
