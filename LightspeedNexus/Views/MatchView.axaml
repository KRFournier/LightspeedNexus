<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LightspeedNexus.ViewModels"
			 xmlns:m="clr-namespace:LightspeedNexus.Models"
			 xmlns:v="clr-namespace:LightspeedNexus.Views"
			 xmlns:c="clr-namespace:LightspeedNexus.Controls"
			 xmlns:cv="clr-namespace:LightspeedNexus.Converters"
             mc:Ignorable="d" d:DesignWidth="240" d:DesignHeight="100"
			 Width="240" Height="100"
			 IsHitTestVisible="False"
             x:Class="LightspeedNexus.Views.MatchView"
			 x:DataType="vm:MatchViewModel">
	
	<Design.DataContext>
		<vm:MatchViewModel>
			<vm:MatchViewModel.First>
				<vm:ScoreViewModel Points="99">
					<vm:ScoreViewModel.Participant>
						<vm:PlayerViewModel Name="Tony Zaldua, Jr."/>
					</vm:ScoreViewModel.Participant>
				</vm:ScoreViewModel>
			</vm:MatchViewModel.First>
			<vm:MatchViewModel.Second>
				<vm:ScoreViewModel Points="-99">
					<vm:ScoreViewModel.Participant>
						<vm:PlayerViewModel Name="Nate McCroskey-Izzet"/>
					</vm:ScoreViewModel.Participant>
				</vm:ScoreViewModel>
			</vm:MatchViewModel.Second>
			<vm:MatchViewModel.IsMatchStarted>true</vm:MatchViewModel.IsMatchStarted>
			<vm:MatchViewModel.Number>7</vm:MatchViewModel.Number>
			<vm:MatchViewModel.IsLive>false</vm:MatchViewModel.IsLive>
			<vm:MatchViewModel.TimeRemaining>00:00:45</vm:MatchViewModel.TimeRemaining>
		</vm:MatchViewModel>
	</Design.DataContext>

	<Grid ColumnDefinitions="7*,3*"
		  RowDefinitions="Auto,*,*">

		<TextBlock FontSize="64" LineHeight="64" FontWeight="Bold" Opacity="0.15"
				   Grid.ColumnSpan="3"
				   Grid.Row="0"
				   Grid.RowSpan="4"
				   Text="{Binding Number}"
				   HorizontalAlignment="Center"
				   VerticalAlignment="Center"
				   IsVisible="{Binding !IsMatchCompleted}"/>

		<Border CornerRadius="0,0,4,4"
				Width="80"
				Height="16"
				Grid.ColumnSpan="3"
				HorizontalAlignment="Center"
				IsVisible="{Binding IsLive}"
				Background="{StaticResource HilightBrush}">
			<StackPanel Orientation="Horizontal"
						HorizontalAlignment="Center"
						Spacing="4">
				<PathIcon Data="{StaticResource video_regular}"
						  Foreground="Black"
						  Height="12"
						  VerticalAlignment="Center"/>
				<TextBlock Classes="info tiny"
						   LineHeight="12"
						   Foreground="Black"
						   VerticalAlignment="Center"
						   Text="{Binding TimeRemaining, StringFormat='m\\:ss'}"/>
			</StackPanel>
		</Border>

		<Viewbox StretchDirection="DownOnly"
				 Grid.Column="0"
				 Grid.Row="1"
				 Margin="15,0,5,0"
				 HorizontalAlignment="Left"
				 VerticalAlignment="Center"
				 Opacity="{Binding IsSecondWinner, Converter={StaticResource TrueToFaded}}">
			<TextBlock Classes="medium info"
					   Text="{Binding First.Participant.Name}"/>
		</Viewbox>

		<Viewbox StretchDirection="DownOnly"
				 Grid.Column="0"
				 Grid.Row="4"
				 Margin="15,0,5,0"
				 HorizontalAlignment="Left"
				 VerticalAlignment="Center"
				 Opacity="{Binding IsFirstWinner, Converter={StaticResource TrueToFaded}}">
			<TextBlock Classes="medium info"
					   HorizontalAlignment="Center"
					   Text="{Binding Second.Participant.Name}"/>
		</Viewbox>

		<TextBlock Classes="large"
				   Grid.Column="2"
				   Grid.Row="1"
				   Margin="5,0,15,0"
				   HorizontalAlignment="Right"
				   VerticalAlignment="Center"
				   IsVisible="{Binding IsMatchStarted}"
				   Text="{Binding First.Points}"
				   Opacity="{Binding IsSecondWinner, Converter={StaticResource TrueToFaded}}"/>

		<TextBlock Classes="large"
				   Grid.Column="2"
				   Grid.Row="4"
				   Margin="5,0,15,0"
				   HorizontalAlignment="Right"
				   VerticalAlignment="Center"
				   IsVisible="{Binding IsMatchStarted}"
				   Text="{Binding Second.Points}"
				   Opacity="{Binding IsFirstWinner, Converter={StaticResource TrueToFaded}}"/>
		
	</Grid>
	
</UserControl>
