<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LightspeedNexus.ViewModels"
			 xmlns:m="clr-namespace:LightspeedNexus.Models"
			 xmlns:v="clr-namespace:LightspeedNexus.Views"
			 xmlns:c="clr-namespace:LightspeedNexus.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LightspeedNexus.Views.SettingsView"
			 x:DataType="vm:SettingsViewModel">

	<Design.DataContext>
		<vm:SettingsViewModel/>
	</Design.DataContext>

	<Grid RowDefinitions="Auto,10,Auto,10,Auto,10,Auto,10,Auto,10,Auto,10,Auto"
		  ColumnDefinitions="Auto,10,*"
		  Grid.IsSharedSizeScope="True">

		<!--Subtitle-->
		<TextBlock Grid.Column="0"
				   Grid.Row="0"
				   VerticalAlignment="Center"
				   Text="Tagline"/>
		<TextBox Grid.Column="2"
				 Grid.Row="0"
				 HorizontalAlignment="Left"
				 MinWidth="400"
				 Watermark="Optional text at the end of the generated title"
				 Text="{Binding SubTitle}"/>
		
		<!--Date-->
		<TextBlock Grid.Column="0"
				   Grid.Row="2"
				   VerticalAlignment="Center"
				   Text="Date"/>
		<CalendarDatePicker Grid.Column="2"
							Grid.Row="2"
							SelectedDate="{Binding Date}"/>

		<!--Skill Level-->
		<TextBlock Grid.Column="0"
				   Grid.Row="4"
				   VerticalAlignment="Center"
				   Text="Skill Level"/>
		<StackPanel Grid.Column="2"
					Grid.Row="4"
					Orientation="Horizontal"
					Spacing="10">
			<RadioButton GroupName="SkillLevel"
						 Theme="{StaticResource RadioButtonButtons}"
						 Width="100"
						 HorizontalContentAlignment="Center"
						 IsChecked="{Binding SkillLevel,
							 Converter={StaticResource RadioValue},
							 ConverterParameter={x:Static m:SkillLevel.Open}}"
						 Content="Open"/>
			<RadioButton GroupName="SkillLevel"
						 Theme="{StaticResource RadioButtonButtons}"
						 Padding="5,5.5,5,5"
						 Width="100"
						 HorizontalContentAlignment="Center"
						 IsChecked="{Binding SkillLevel,
							 Converter={StaticResource RadioValue},
							 ConverterParameter={x:Static m:SkillLevel.Advanced}}"
						 Content="Advanced"/>
			<RadioButton GroupName="SkillLevel"
						 Theme="{StaticResource RadioButtonButtons}"
						 Width="100"
						 HorizontalContentAlignment="Center"
						 IsChecked="{Binding SkillLevel,
							 Converter={StaticResource RadioValue},
							 ConverterParameter={x:Static m:SkillLevel.Novice}}"
						 Content="Novice"/>
		</StackPanel>
		
		<!--Demographic-->
		<TextBlock Grid.Column="0"
				   Grid.Row="6"
				   VerticalAlignment="Center"
				   Text="Demographic"/>
		<StackPanel Grid.Column="2"
					Grid.Row="6"
					Orientation="Horizontal"
					Spacing="10">
			<RadioButton GroupName="Demographic"
						 Theme="{StaticResource RadioButtonButtons}"
						 Width="100"
						 HorizontalContentAlignment="Center"
						 IsChecked="{Binding Demographic,
							 Converter={StaticResource RadioValue},
							 ConverterParameter={x:Static m:Demographic.All}}"
						 Content="All"/>
			<RadioButton GroupName="Demographic"
						 Theme="{StaticResource RadioButtonButtons}"
						 Width="100"
						 HorizontalContentAlignment="Center"
						 IsChecked="{Binding Demographic,
							 Converter={StaticResource RadioValue},
							 ConverterParameter={x:Static m:Demographic.Women}}"
						 Content="Women"/>
			<RadioButton GroupName="Demographic"
						 Theme="{StaticResource RadioButtonButtons}"
						 Width="100"
						 HorizontalContentAlignment="Center"
						 IsChecked="{Binding Demographic,
							 Converter={StaticResource RadioValue},
							 ConverterParameter={x:Static m:Demographic.Cadet}}"
						 Content="Cadet"/>
		</StackPanel>

		<!--Weapons-->
		<TextBlock Grid.Column="0"
				   Grid.Row="8"
				   VerticalAlignment="Center"
				   Text="Weapons"/>
		<StackPanel Grid.Column="2"
					Grid.Row="8"
					Orientation="Horizontal"
					Spacing="10"
					HorizontalAlignment="Left">
			<ToggleButton IsChecked="{Binding ReyAllowed}"
							Width="100"
							ToolTip.Tip="Allow Rey"
							VerticalAlignment="Stretch"
							HorizontalContentAlignment="Center">
				<StackPanel Orientation="Horizontal"
							Spacing="2">
					<Image Height="30" Source="{StaticResource di_Rey}"/>
					<TextBlock VerticalAlignment="Center">Rey</TextBlock>
				</StackPanel>
			</ToggleButton>
			<ToggleButton IsChecked="{Binding RenAllowed}"
							Width="100"
							ToolTip.Tip="Allow Ren"
							VerticalAlignment="Stretch"
							HorizontalContentAlignment="Center">
				<StackPanel Orientation="Horizontal"
							Spacing="2">
					<Image Height="30" Source="{StaticResource di_Ren}"/>
					<TextBlock VerticalAlignment="Center">Ren</TextBlock>
				</StackPanel>
			</ToggleButton>
			<ToggleButton IsChecked="{Binding TanoAllowed}"
							Width="100"
							ToolTip.Tip="Allow Tano"
							VerticalAlignment="Stretch"
							HorizontalContentAlignment="Center">
				<StackPanel Orientation="Horizontal"
							Spacing="2">
					<Image Height="30" Source="{StaticResource di_Tano}"/>
					<TextBlock VerticalAlignment="Center">Tano</TextBlock>
				</StackPanel>
			</ToggleButton>
		</StackPanel>

		<!--Pools-->
		<TextBlock Grid.Column="0"
				   Grid.Row="10"
				   VerticalAlignment="Center"
				   Text="Pools"/>
		<c:MatchSettings Grid.Column="2"
						 Grid.Row="10"
						 Height="75"
						 Width="260"
						 Score="{Binding PoolSettings.WinningScore}"
						 Time="{Binding PoolSettings.TimeLimit}"
						 HorizontalAlignment="Left"/>

		<!--Bracket-->
		<TextBlock Grid.Column="0"
				   Grid.Row="12"
				   VerticalAlignment="Center"
				   Text="Bracket"/>
		<StackPanel Grid.Column="2"
					Grid.Row="12"
					Orientation="Horizontal"
					Spacing="10">
			<c:MatchSettings Height="75"
							 Width="260"							 
							 Score="{Binding BracketSettings.WinningScore}"
							 Time="{Binding BracketSettings.TimeLimit}"
							 HorizontalAlignment="Left"/>
			<Grid RowDefinitions="*,*">
				<CheckBox Grid.Row="0"
						  Content="Third Place Match"
						  IsChecked="{Binding BracketSettings.HasThirdPlaceMatch}"/>
				<CheckBox Grid.Row="1"
						  Content="100% Advancement"
						  IsChecked="{Binding BracketSettings.IsFullAdvancement}"/>
			</Grid>
		</StackPanel>
		
	</Grid>
	
</UserControl>
