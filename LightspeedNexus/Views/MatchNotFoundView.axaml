<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LightspeedNexus.ViewModels"
			 xmlns:m="clr-namespace:LightspeedNexus.Models"
			 xmlns:v="clr-namespace:LightspeedNexus.Views"
			 xmlns:c="clr-namespace:LightspeedNexus.Controls"
			 xmlns:cv="clr-namespace:LightspeedNexus.Converters"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="100"
			 Width="300" Height="100"
			 IsHitTestVisible="False"
             x:Class="LightspeedNexus.Views.MatchNotFoundView"
			 x:DataType="vm:MatchNotFoundViewModel">

	<StackPanel VerticalAlignment="Center"
				HorizontalAlignment="Center"
				Orientation="Horizontal"
				Spacing="10">
		<PathIcon Data="{StaticResource warning_regular}"
				  VerticalAlignment="Center"
				  HorizontalAlignment="Center"/>
		<TextBlock Classes="info medium"
				   Grid.Row="1"
				   HorizontalAlignment="Center"
				   Text="Match not found!"/>		
	</StackPanel>
	
</UserControl>
