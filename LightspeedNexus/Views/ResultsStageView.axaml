<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:LightspeedNexus.ViewModels"
			 xmlns:m="clr-namespace:LightspeedNexus.Models"
			 xmlns:v="clr-namespace:LightspeedNexus.Views"
			 xmlns:c="clr-namespace:LightspeedNexus.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 ClipToBounds="False"
             x:Class="LightspeedNexus.Views.ResultsStageView"
			 x:DataType="vm:ResultsStageViewModel">

	<Design.DataContext>
		<vm:ResultsStageViewModel/>
	</Design.DataContext>

	<Grid x:Name="Root" RowDefinitions="Auto,10,*">

		<!--Header-->
		<Grid ColumnDefinitions="260,10,*,10,260">

			<Button HorizontalAlignment="Stretch"
					VerticalAlignment="Stretch"
					HorizontalContentAlignment="Center"
					VerticalContentAlignment="Center"
					Command="{Binding GoBackCommand}">
				<StackPanel>
					<StackPanel>
						<StackPanel Orientation="Horizontal"
									Spacing="10">
							<PathIcon Data="{StaticResource arrow_left_regular}"/>
							<TextBlock Classes="large" Text="Bracket"/>
						</StackPanel>
					</StackPanel>
				</StackPanel>
			</Button>

			<StackPanel Grid.Column="2" VerticalAlignment="Center">
				<TextBlock Classes="small info"						   
						   HorizontalAlignment="Center"
						   Text="{Binding Event}"
						   IsVisible="{Binding Event, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
				<TextBlock Classes="giant"
						   HorizontalAlignment="Center"
						   Text="{Binding Title}"/>
			</StackPanel>
			
			<Button Grid.Column="4"
					HorizontalAlignment="Stretch"
					VerticalAlignment="Stretch"
					HorizontalContentAlignment="Center"
					VerticalContentAlignment="Center"
					Command="{Binding CloseCommand}">
				<TextBlock Classes="large" Text="Close"/>
			</Button>

		</Grid>
		
		<!--Rankings-->
		<Grid Grid.Row="2" RowDefinitions="Auto,10,Auto,10,*">
		
			<Grid ColumnDefinitions="50,10,*,10,100,10,100,10,100,10,100"
				  Margin="12,0"
				  Grid.Row="2">
				<TextBlock Grid.Column="0" HorizontalAlignment="Center">Place</TextBlock>
				<TextBlock Grid.Column="2">Name</TextBlock>
				<TextBlock Grid.Column="4" HorizontalAlignment="Center">Overall Wins</TextBlock>
				<TextBlock Grid.Column="6" HorizontalAlignment="Center">Points</TextBlock>
				<TextBlock Grid.Column="8" HorizontalAlignment="Center">Current Rank</TextBlock>
				<TextBlock Grid.Column="10" HorizontalAlignment="Center">Promotion</TextBlock>
			</Grid>
			
			<!-- Players -->
			<ScrollViewer Grid.Row="4">
				<ItemsControl ItemsSource="{Binding Placements}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Spacing="10"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate DataType="vm:StatisticsViewModel">
							<c:LightspeedBorder Classes="item"
								Classes.gold="{Binding IsGold}"
								Classes.silver="{Binding IsSilver}"
								Classes.bronze="{Binding IsBronze}">
								<Grid ColumnDefinitions="50,10,*,10,100,10,100,10,100,10,100">
									<TextBlock Grid.Column="0"
											   Classes="medium"
											   Text="{Binding Place}"
											   HorizontalAlignment="Center"
											   VerticalAlignment="Center"/>
									<TextBlock Grid.Column="2"
											   Classes="large"
											   Text="{Binding Participant.Name}"
											   VerticalAlignment="Center"/>
									<TextBlock Grid.Column="4"
											   Classes="medium"
											   Text="{Binding Wins}"
											   HorizontalAlignment="Center"
											   VerticalAlignment="Center"/>
									<TextBlock Grid.Column="6"
											   Classes="medium"
											   Text="{Binding Points}"
											   HorizontalAlignment="Center"
											   VerticalAlignment="Center"/>
									<TextBlock Grid.Column="8"
											   Classes="large"
											   Text="{Binding OldRank}"
											   Foreground="{StaticResource GrayBrush}"
											   HorizontalAlignment="Center"
											   VerticalAlignment="Center"/>
									<TextBlock Grid.Column="10"
											   Classes="large"
											   IsVisible="{Binding IsPromoted}"
											   Text="{Binding NewRank}"
											   HorizontalAlignment="Center"
											   VerticalAlignment="Center"/>
								</Grid>
							</c:LightspeedBorder>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>

		</Grid>
		
	</Grid>
</UserControl>
